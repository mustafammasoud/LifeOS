<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:vm="using:LifeOS.Desktop.ViewModels.Pages"
             xmlns:tasks="using:LifeOS.Domain.Tasks"
             xmlns:cal="using:LifeOS.Domain.Calendar"
             xmlns:habits="using:LifeOS.Application.Habits"
             xmlns:goals="using:LifeOS.Application.Goals"
             xmlns:activity="using:LifeOS.Domain.Activity"
             xmlns:conv="using:LifeOS.Desktop.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="LifeOS.Desktop.Views.Pages.DashboardView"
             x:DataType="vm:DashboardViewModel">

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="20">

            <!-- Header -->
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Image Source="/Assets/logo.png" Width="28" Height="28" />
                    <TextBlock Text="{Binding Greeting}" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="{Binding TodayLabel}" FontSize="14" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" />
            </StackPanel>

            <!-- Quick Stats -->
            <UniformGrid Columns="5">
                <Border Classes="Card" Margin="0,0,8,0" Padding="16" CornerRadius="12">
                    <StackPanel Spacing="8">
                        <mi:MaterialIcon Kind="CheckboxMarkedCircleOutline" Width="20" Height="20" Foreground="#4ADE80" />
                        <TextBlock Text="{Binding TasksTodayCount}" FontSize="22" FontWeight="Bold" />
                        <TextBlock Text="Tasks Today" FontSize="12" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" />
                    </StackPanel>
                </Border>

                <Border Classes="Card" Margin="0,0,8,0" Padding="16" CornerRadius="12">
                    <StackPanel Spacing="8">
                        <mi:MaterialIcon Kind="BookOpenPageVariantOutline" Width="20" Height="20" Foreground="#60A5FA" />
                        <TextBlock Text="{Binding StudyMinutesToday, StringFormat='{}{0}m'}" FontSize="22" FontWeight="Bold" />
                        <TextBlock Text="Study" FontSize="12" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" />
                    </StackPanel>
                </Border>

                <Border Classes="Card" Margin="0,0,8,0" Padding="16" CornerRadius="12">
                    <StackPanel Spacing="8">
                        <mi:MaterialIcon Kind="Repeat" Width="20" Height="20" Foreground="#FB923C" />
                        <TextBlock Text="{Binding HabitsCompletedToday}" FontSize="22" FontWeight="Bold" />
                        <TextBlock Text="Habits Done" FontSize="12" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" />
                    </StackPanel>
                </Border>

                <Border Classes="Card" Margin="0,0,8,0" Padding="16" CornerRadius="12">
                    <StackPanel Spacing="8">
                        <mi:MaterialIcon Kind="TimerOutline" Width="20" Height="20" Foreground="#C084FC" />
                        <TextBlock Text="{Binding FocusMinutesToday, StringFormat='{}{0}m'}" FontSize="22" FontWeight="Bold" />
                        <TextBlock Text="Focus Time" FontSize="12" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" />
                    </StackPanel>
                </Border>

                <Border Classes="Card" Padding="16" CornerRadius="12">
                    <StackPanel Spacing="8">
                        <mi:MaterialIcon Kind="Fire" Width="20" Height="20" Foreground="#F87171" />
                        <TextBlock Text="{Binding BestStreak}" FontSize="22" FontWeight="Bold" />
                        <TextBlock Text="Best Streak" FontSize="12" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Tasks + Schedule -->
            <Grid ColumnDefinitions="*,*">
                <Border Classes="Card" Grid.Column="0" Margin="0,0,8,0" Padding="18" CornerRadius="12">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="CheckboxMarkedCircleOutline" Width="18" Height="18" Foreground="#4ADE80" />
                            <TextBlock Text="Today's Tasks" FontWeight="SemiBold" FontSize="15" />
                        </StackPanel>

                        <TextBlock Text="No tasks for today" FontSize="13" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"
                                   IsVisible="{Binding !TodayTasks.Count}" Margin="0,8" />

                        <ItemsControl ItemsSource="{Binding TodayTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="tasks:TaskItem">
                                    <DockPanel Margin="0,4">
                                        <Border DockPanel.Dock="Left" Width="4" CornerRadius="2" Margin="0,0,8,0" Height="18"
                                                Background="{Binding Priority, Converter={x:Static conv:PriorityColorConverter.Instance}}" />
                                        <CheckBox
                                               DockPanel.Dock="Left"
                                               IsChecked="{Binding IsCompleted}"
                                               IsHitTestVisible="False" />
                                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                         <Button
                            Content="View All Tasks →"
                            HorizontalAlignment="Right"
                            Margin="0,8,0,0"
                            Command="{Binding ViewAllTasksCommand}" />
                    </StackPanel>
                </Border>

                <Border Classes="Card" Grid.Column="1" Margin="8,0,0,0" Padding="18" CornerRadius="12">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="CalendarMonthOutline" Width="18" Height="18" Foreground="#60A5FA" />
                            <TextBlock Text="Today's Schedule" FontWeight="SemiBold" FontSize="15" />
                        </StackPanel>

                        <TextBlock Text="No events scheduled today" FontSize="13" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"
                                   IsVisible="{Binding !TodaySchedule.Count}" Margin="0,8" />

                        <ItemsControl ItemsSource="{Binding TodaySchedule}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="cal:CalendarEvent">
                                    <DockPanel Margin="0,4">
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding StartTime, StringFormat='{}{0:hh\\:mm tt}'}"
                                                   Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" FontSize="12" />
                                        <TextBlock Text="{Binding Title}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Habits + Quick Note -->
            <Grid ColumnDefinitions="*,*">
                <Border Classes="Card" Grid.Column="0" Margin="0,0,8,0" Padding="18" CornerRadius="12">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="Repeat" Width="18" Height="18" Foreground="#FB923C" />
                            <TextBlock Text="Habits" FontWeight="SemiBold" FontSize="15" />
                        </StackPanel>

                        <TextBlock Text="No habits tracked yet" FontSize="13" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"
                                   IsVisible="{Binding !TodayHabits.Count}" Margin="0,8" />

                        <ItemsControl ItemsSource="{Binding TodayHabits}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="habits:HabitProgress">
                                    <DockPanel Margin="0,4">
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding CurrentStreak, StringFormat='{}{0}d'}"
                                                   Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" FontSize="12" />
                                        <TextBlock Text="{Binding Habit.Name}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Classes="Card" Grid.Column="1" Margin="8,0,0,0" Padding="18" CornerRadius="12">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="NoteTextOutline" Width="18" Height="18" Foreground="#A78BFA" />
                            <TextBlock Text="Quick Note" FontWeight="SemiBold" FontSize="15" />
                        </StackPanel>

                        <TextBlock Text="No notes yet" FontSize="13" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"
                                   IsVisible="{Binding LatestNote, Converter={x:Static ObjectConverters.IsNull}}" />

                        <StackPanel IsVisible="{Binding LatestNote, Converter={x:Static ObjectConverters.IsNotNull}}">
                            <TextBlock Text="{Binding LatestNote.Title}" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock Text="{Binding LatestNote.ContentMarkdown}" TextWrapping="Wrap" MaxLines="3"
                                       FontSize="12" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Goals + Recent Activity -->
            <Grid ColumnDefinitions="*,*">
                <Border Classes="Card" Grid.Column="0" Margin="0,0,8,0" Padding="18" CornerRadius="12">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="FlagCheckered" Width="18" Height="18" Foreground="#C084FC" />
                            <TextBlock Text="Goals Progress" FontWeight="SemiBold" FontSize="15" />
                        </StackPanel>

                        <TextBlock Text="No active goals" FontSize="13" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"
                                   IsVisible="{Binding !TopGoals.Count}" Margin="0,8" />

                        <ItemsControl ItemsSource="{Binding TopGoals}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="goals:GoalProgress">
                                    <StackPanel Margin="0,4" Spacing="4">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right" Text="{Binding ProgressPercent, StringFormat='{}{0}%'}" />
                                            <TextBlock Text="{Binding Goal.Title}" />
                                        </DockPanel>
                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressPercent}" Height="4" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Classes="Card" Grid.Column="1" Margin="8,0,0,0" Padding="18" CornerRadius="12">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <mi:MaterialIcon Kind="ClockOutline" Width="18" Height="18" Foreground="#F472B6" />
                            <TextBlock Text="Recent Activity" FontWeight="SemiBold" FontSize="15" />
                        </StackPanel>

                        <TextBlock Text="No activity yet today" FontSize="13" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"
                                   IsVisible="{Binding !RecentActivity.Count}" Margin="0,8" />

                        <ItemsControl ItemsSource="{Binding RecentActivity}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="activity:ActivityLogEntry">
                                    <DockPanel Margin="0,4">
                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Timestamp, StringFormat='{}{0:hh\\:mm tt}'}"
                                                   FontSize="11" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" />
                                        <TextBlock Text="{Binding Icon}" Margin="0,0,6,0" />
                                        <TextBlock Text="{Binding Title}" FontSize="12" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>

</UserControl>