<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LifeOS.Desktop.ViewModels.Pages"
             xmlns:cal="using:LifeOS.Domain.Calendar"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="LifeOS.Desktop.Views.Pages.CalendarView"
             x:DataType="vm:CalendarViewModel">

    <Grid ColumnDefinitions="Auto,*" Margin="24">

        <StackPanel Grid.Column="0" Spacing="16" Margin="0,0,24,0">
            <CalendarDatePicker SelectedDate="{Binding SelectedDate}" />

            <Border Classes="Card">
                <StackPanel Spacing="8">
                    <TextBlock Text="New Event" FontWeight="SemiBold" />
                    <TextBox Text="{Binding NewTitle}" Watermark="Title..." />
                    <TextBlock Text="Start" FontSize="12" />
                    <TimePicker SelectedTime="{Binding NewStartTime}" />
                    <TextBlock Text="End" FontSize="12" />
                    <TimePicker SelectedTime="{Binding NewEndTime}" />
                    <Button Content="Add" Command="{Binding AddEventCommand}" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Column="1" Spacing="8">
            <TextBlock Text="Events" FontSize="20" FontWeight="SemiBold" />
            <ItemsControl ItemsSource="{Binding Events}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="cal:CalendarEvent">
                        <Border Classes="Card" Margin="0,4">
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="Delete"
                                        Command="{Binding $parent[ItemsControl].((vm:CalendarViewModel)DataContext).DeleteEventCommand}"
                                        CommandParameter="{Binding}" />
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding StartTime, StringFormat='{}{0:hh\\:mm tt}'}"
                                               FontSize="12" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

    </Grid>

</UserControl>

