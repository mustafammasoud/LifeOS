<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LifeOS.Desktop.ViewModels.Pages"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="LifeOS.Desktop.Views.Pages.ComingSoonView"
             x:DataType="vm:ComingSoonViewModel">

    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8">
        <TextBlock Text="{Binding PageName}"
                   FontSize="24"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center" />
        <TextBlock Text="Coming soon..."
                   Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"
                   HorizontalAlignment="Center" />
    </StackPanel>

</UserControl>