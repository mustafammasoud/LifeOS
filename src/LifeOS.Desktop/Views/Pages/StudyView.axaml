<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LifeOS.Desktop.ViewModels.Pages"
             xmlns:study="using:LifeOS.Domain.Study"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="LifeOS.Desktop.Views.Pages.StudyView"
             x:DataType="vm:StudyViewModel">

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="20" MaxWidth="600">

            <TextBlock Text="Study" FontSize="24" FontWeight="SemiBold" />

            <!-- Pomodoro Timer -->
            <Border Classes="Card">
                <StackPanel Spacing="12" HorizontalAlignment="Center">

                    <TextBlock Text="{Binding TimeDisplay}" FontSize="48" FontWeight="Bold"
                               HorizontalAlignment="Center" />

                    <ComboBox ItemsSource="{Binding DurationOptions}"
                           SelectedItem="{Binding DurationMinutes}"
                                IsEnabled="{Binding !IsRunning}" />

                    <ComboBox ItemsSource="{Binding Subjects}"
                              SelectedItem="{Binding SelectedSubject}"
                              PlaceholderText="Subject (optional)"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="study:Subject">
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBox Text="{Binding SessionNotes}" Watermark="Notes for this session..." />

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Button Content="Start" Command="{Binding StartCommand}"
                                IsEnabled="{Binding !IsRunning}" />
                        <Button Content="Pause" Command="{Binding PauseCommand}"
                                IsEnabled="{Binding IsRunning}" />
                        <Button Content="Reset" Command="{Binding ResetCommand}" />
                    </StackPanel>

                    <TextBlock Text="{Binding TodayFocusMinutes, StringFormat='Focused {0} min today'}"
                               Foreground="{DynamicResource LifeOS.Brush.TextSecondary}"
                               HorizontalAlignment="Center" FontSize="12" />
                </StackPanel>
            </Border>

            <!-- Add Subject -->
            <Border Classes="Card">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="Add"
                            Command="{Binding AddSubjectCommand}" Margin="8,0,0,0" />
                    <TextBox Text="{Binding NewSubjectName}" Watermark="New subject..." />
                </DockPanel>
            </Border>

            <!-- Today's Sessions -->
            <TextBlock Text="Today's Sessions" FontWeight="SemiBold" FontSize="16" />
            <ItemsControl ItemsSource="{Binding TodaySessions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="study:PomodoroSession">
                        <Border Classes="Card" Margin="0,4">
                            <StackPanel>
                                <TextBlock Text="{Binding DurationMinutes, StringFormat='{}{0} min session'}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Notes}"
                                           IsVisible="{Binding Notes, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                           FontSize="12" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ItemsControl ItemsSource="{Binding Subjects}">
                  <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="study:Subject">
                          <DockPanel Margin="0,4">
                              <Button DockPanel.Dock="Right" Content="✕"
                                      Command="{Binding $parent[ItemsControl].((vm:StudyViewModel)DataContext).DeleteSubjectCommand}"
                                      CommandParameter="{Binding}" />
                              <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                          </DockPanel>
                      </DataTemplate>
                  </ItemsControl.ItemTemplate>
              </ItemsControl>

        </StackPanel>
    </ScrollViewer>

</UserControl>