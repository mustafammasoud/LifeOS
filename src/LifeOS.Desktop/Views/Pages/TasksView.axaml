<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LifeOS.Desktop.ViewModels.Pages"
             xmlns:tasks="using:LifeOS.Domain.Tasks"
             xmlns:conv="using:LifeOS.Desktop.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="LifeOS.Desktop.Views.Pages.TasksView"
             x:DataType="vm:TasksViewModel">

    <ScrollViewer>
        <StackPanel Margin="24" Spacing="16" MaxWidth="650">

            <TextBlock Text="Tasks" FontSize="24" FontWeight="SemiBold" />

            <UniformGrid Columns="3">
                <Border Classes="Card" Margin="0,0,8,0" Padding="14" CornerRadius="10">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding TotalCount}" FontSize="20" FontWeight="Bold" />
                        <TextBlock Text="Total" FontSize="12" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" />
                    </StackPanel>
                </Border>
                <Border Classes="Card" Margin="0,0,8,0" Padding="14" CornerRadius="10">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding CompletedCount}" FontSize="20" FontWeight="Bold" Foreground="#4ADE80" />
                        <TextBlock Text="Completed" FontSize="12" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" />
                    </StackPanel>
                </Border>
                <Border Classes="Card" Padding="14" CornerRadius="10">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding RemainingCount}" FontSize="20" FontWeight="Bold" Foreground="#FBBF24" />
                        <TextBlock Text="Remaining" FontSize="12" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Classes="Card">
                <StackPanel Spacing="10">
                    <TextBox Text="{Binding NewTaskTitle}" Watermark="New task..." />
                    <ComboBox ItemsSource="{Binding PriorityOptions}"
                              SelectedItem="{Binding NewTaskPriority}" />
                    <TextBox Text="{Binding NewTaskTagsText}" Watermark="Tags (comma separated, e.g. work, study)" />
                    <Button Content="Add" Command="{Binding AddTaskCommand}" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <!-- Tag filter bar -->
            <ItemsControl ItemsSource="{Binding AvailableTags}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Button Content="{Binding}" Margin="0,0,6,6" Padding="10,4" CornerRadius="12"
                                Command="{Binding $parent[ItemsControl].((vm:TasksViewModel)DataContext).SetTagFilterCommand}"
                                CommandParameter="{Binding}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="✕ Clear filter" HorizontalAlignment="Left"
                    Command="{Binding ClearTagFilterCommand}"
                    IsVisible="{Binding SelectedTagFilter, Converter={x:Static ObjectConverters.IsNotNull}}" />

            <ItemsControl ItemsSource="{Binding FilteredTasks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="tasks:TaskItem">
                        <Border Classes="Card" Margin="0,4">
                            <StackPanel>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="Delete"
                                            Command="{Binding $parent[ItemsControl].((vm:TasksViewModel)DataContext).DeleteTaskCommand}"
                                            CommandParameter="{Binding}" />

                                    <Border DockPanel.Dock="Left" Width="4" CornerRadius="2" Margin="0,0,10,0"
                                            Background="{Binding Priority, Converter={x:Static conv:PriorityColorConverter.Instance}}" />

                                    <CheckBox DockPanel.Dock="Left"
                                        IsChecked="{Binding IsCompleted}"
                                        Command="{Binding $parent[ItemsControl].((vm:TasksViewModel)DataContext).ToggleCompleteCommand}"
                                        CommandParameter="{Binding}"
                                        IsEnabled="True" />

                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                </DockPanel>

                                <ItemsControl ItemsSource="{Binding Tags}" Margin="26,6,0,0"
                                              IsVisible="{Binding Tags.Count}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Border Background="{DynamicResource LifeOS.Brush.CardBackgroundHover}"
                                                    CornerRadius="8" Padding="8,2" Margin="0,0,6,0">
                                                <TextBlock Text="{Binding}" FontSize="11" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>

</UserControl>