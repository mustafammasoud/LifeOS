<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LifeOS.Desktop.Controls.RingProgress"
             x:Name="Root">
    <StackPanel Spacing="8" HorizontalAlignment="Center">
        <Grid Width="120" Height="120">
            <Ellipse Width="120" Height="120" Stroke="#2A2A30" StrokeThickness="10" />
            <Path x:Name="ArcPath" Stroke="{Binding #Root.RingColor}"
                  StrokeThickness="10" StrokeLineCap="Round" />
            <TextBlock Text="{Binding #Root.Percentage, StringFormat='{}{0:0}%'}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="20" FontWeight="Bold" />
        </Grid>
        <TextBlock Text="{Binding #Root.Label}" HorizontalAlignment="Center"
                   FontSize="12" Foreground="{DynamicResource LifeOS.Brush.TextSecondary}" />
    </StackPanel>
</UserControl>

